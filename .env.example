# Qobuz API Credentials
# Copy this file to .env and fill in your values.
# File permissions will be set to 0600 (owner-only) automatically.

# Application credentials (auto-extracted from web player if not set).
# Uncomment and set these only if auto-extraction fails.
# QOBUZ_APP_ID=
# QOBUZ_APP_SECRET=

# Email/password authentication.
QOBUZ_EMAIL=
QOBUZ_PASSWORD=

# Token-based authentication (alternative to email/password).
# QOBUZ_USER_ID=
# QOBUZ_USER_AUTH_TOKEN=
