# Qobuz API Credentials
# Copy this file to .env and fill in your values.
# File permissions will be set to 0600 (owner-only) automatically.

# Application credentials (auto-extracted from web player if not set).
# Uncomment and set these only if auto-extraction fails.
# QOBUZ_APP_ID=
# QOBUZ_APP_SECRET=

# Email/password authentication.
QOBUZ_EMAIL=
QOBUZ_PASSWORD=

# Token-based authentication (alternative to email/password).
# QOBUZ_USER_ID=
# QOBUZ_USER_AUTH_TOKEN=

# Search integration test keywords (optional - defaults shown below)
# TEST_SEARCH_ALBUM_QUERY_1="The Dark Side of the Moon Pink Floyd"
# TEST_SEARCH_ALBUM_QUERY_2="Kind of Blue Miles Davis"
# TEST_SEARCH_ARTIST_QUERY_1="Miles Davis"
# TEST_SEARCH_ARTIST_QUERY_2="Radiohead"
# TEST_SEARCH_TRACK_QUERY_1="So What Miles Davis"
# TEST_SEARCH_TRACK_QUERY_2="Bohemian Rhapsody Queen"
# TEST_SEARCH_PLAYLIST_QUERY_1="jazz"
# TEST_SEARCH_CATALOG_QUERY="Miles Davis"
# TEST_SEARCH_PAGINATION_QUERY="Rock"

# Browse integration test queries (optional - defaults shown below)
# TEST_BROWSE_ALBUM_QUERY="Kind of Blue Miles Davis"
# TEST_BROWSE_ARTIST_QUERY="Miles Davis"
# TEST_BROWSE_TRACK_QUERY="So What Miles Davis"
# TEST_BROWSE_PLAYLIST_QUERY="jazz classics"
# TEST_BROWSE_RELEASE_LIST_QUERY="John Coltrane"

# Download integration test settings (optional - defaults shown below)
# TEST_DOWNLOAD_TRACK_QUERY="So What Miles Davis"
# TEST_DOWNLOAD_ALBUM_QUERY="Kind of Blue Miles Davis"
# TEST_DOWNLOAD_FORMAT_ID=5
